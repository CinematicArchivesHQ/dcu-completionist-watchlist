rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Each signed-in user can access only records below their own UID.
    // This safely supports all Cinematic Archives projects with isolated archive documents.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }
  }
}
